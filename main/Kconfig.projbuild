menu "StudioPieters"

    comment "For more information visit www.studiopieters.nl"

    config ESP_RELAY_GPIO
        int "Relay GPIO"
        default 16 if IDF_TARGET_ESP32
        default 6  if IDF_TARGET_ESP32C3
        range 0 39
        help
            GPIO driving the relay transistor/driver.
            For ESP32: must be output-capable (0..33). Do NOT use GPIO6..11 (flash).

    config ESP_BLUE_LED_GPIO
        int "Blue LED GPIO"
        default 2  if IDF_TARGET_ESP32
        default 20 if IDF_TARGET_ESP32C3
        range 0 39
        help
            GPIO driving blue LED.
            Note: GPIO2 is a boot strap pin; OK on most devkits/onboard LEDs.

    config ESP_RED_LED_GPIO
        int "Red LED GPIO"
        default 19 if IDF_TARGET_ESP32
        default 3  if IDF_TARGET_ESP32C3
        range 0 39
        help
            GPIO driving red LED.

    config ESP_BUTTON_GPIO
        int "Button GPIO"
        default 23 if IDF_TARGET_ESP32
        default 7  if IDF_TARGET_ESP32C3
        range 0 39
        help
            Button input GPIO (active-low if using button_active_low).
            If using GPIO34..39 on ESP32: these pins are input-only and have NO internal pullups.

    config ESP_SETUP_CODE
        string "HomeKit Setup Code"
        default "693-41-208"
        help
            Configure the HomeKit setup code (update your QR code when changing this value).

    config ESP_SETUP_ID
        string "HomeKit Setup ID"
        default "M4T8"
        help
            Configure the HomeKit setup identifier (update your QR code when changing this value).
endmenu


menu "BL0937 Energy Monitor"

    config ESP_BL0937_CF_GPIO
        int "CF GPIO (pulse input)"
        default 34 if IDF_TARGET_ESP32
        default 4  if IDF_TARGET_ESP32C3
        range 0 39
        help
            BL0937 CF output -> ESP32 input (pulse count).

    config ESP_BL0937_CF1_GPIO
        int "CF1 GPIO (pulse input)"
        default 35 if IDF_TARGET_ESP32
        default 5  if IDF_TARGET_ESP32C3
        range 0 39
        help
            BL0937 CF1 output -> ESP32 input (pulse count).

    config ESP_BL0937_SEL_GPIO
        int "SEL GPIO (output)"
        default 25 if IDF_TARGET_ESP32
        default 21 if IDF_TARGET_ESP32C3
        range 0 39
        help
            BL0937 SEL control -> ESP32 output.
            On ESP32: must be output-capable (0..33). Do NOT use GPIO34..39.

endmenu
